<div class="layout layout--col layout--top layout--shrink-y">
  <div class="flex w--full">
    <div class="item mb--2">
      <div class="meta"></div>
      <div class="content">
        <div id="{{ pollen_chart_id }}" class="w--28 h--28 lg:w--56 lg:h--56">Loading ...</div>
        <span class="label label--small">Pollen Count</span>
      </div>
    </div>

    <div class="item mb--2">
      <div class="meta"></div>
      <div class="content">
        <div id="{{ aqi_chart_id }}" class="w--28 h--28 lg:w--56 lg:h--56">Loading ...</div>
        <span class="label label--small">AQI ({{ features.first.properties.Category }})</span>
      </div>
    </div>
  </div>

  <div class="item mb--2">
    <div class="meta"></div>
    <div class="content">
      <span class="value value--xsmall py--2" data-value-fit="true">{% render 'format_pollen_label', properties: features.first.properties %}</span>
      <span class="label label--small">Pollen Type</span>
    </div>
  </div>
</div>
<div class="layout layout--row layout--stretch-y">
  <div class="h--full w--full">
    <table class="table table--condensed" data-table-limit="true" table-overflow-counter="false">
      <thead>
        <tr>
          <th><span class="label label--small lg:label--base">Date</span></th>
          <th><span class="label label--small lg:label--base text--center">Count</span></th>
          <th><span class="label label--small lg:label--base">Type</span></th>
          <th><span class="label label--small lg:label--base text--center">AQI</span></th>
          <th><span class="label label--small lg:label--base">&nbsp;</span></th>
        </tr>
      </thead>
      <tbody id="pollen-tbody">
        {% for row in features offset: 1 %}
        <tr>
          <td><span class="label label--small lg:label--base">{{ row.properties.ReportDateTime | divided_by: 1000 | date: '%-m/%-d/%Y' }}</span></td>
          <td class="text--center"><span class="value value--xxsmall lg:value--xsmall value--tnums" data-value-format="true">{{ row.properties.PollenCount }}</span></td>
          <td><span class="label label--small lg:label--base">{% render 'format_pollen_label', properties: row.properties %}</span></td>
          <td class="text--center"><span class="value value--xxsmall lg:value--xsmall value--tnums" data-value-format="true">{{ row.properties.AQI }}</span></td>
          <td><span class="label label--small lg:label--base">{{ row.properties.Category }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<div class="title_bar">
  <img class="image image-stroke image-stroke--medium" src="https://raw.githubusercontent.com/stephenyeargin/trmnl-nashville-pollen-aqi/refs/heads/main/assets/mnhd.png" width="28" height="28">
  <span class="title">Report for {{ features.first.properties.ReportDateTime |  divided_by: 1000 | date: '%-m/%-d/%Y' }}</span>
</div>


<script>
  if (typeof window["{{ load_gauges_fn }}"] === "function") {
    window["{{ load_gauges_fn }}"]();
  }
</script>
